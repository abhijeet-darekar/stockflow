            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"defaultLowStockThreshold\": 10\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/settings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "settings"]
            },
            "description": "Update the default low stock threshold for the organization."
          }
        }
      ]
    },
