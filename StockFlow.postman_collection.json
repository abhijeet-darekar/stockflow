            "url": {
              "raw": "{{baseUrl}}/api/settings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "settings"]
            },
            "description": "Get organization settings including default low stock threshold."
          }
        },
        {
          "name": "Update Settings",
          "event": [
            {
              "listen": "test",
